{
  "name": "krf",
  "version": "1.0.0",
  "description": "Generated by [Rojo](https://github.com/rojo-rbx/rojo) 7.6.1.",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "prepare": "husky",
    "test:lint": "stylua --check src tests && selene src tests",
    "test:unit": "powershell -ExecutionPolicy Bypass -File ./scripts/test.ps1 && npm run coverage",
    "coverage:prepare": "node ./scripts/prepare-nyc-coverage.cjs",
    "coverage:report": "npx nyc report",
    "coverage:check": "npx nyc check-coverage",
    "coverage": "npm run coverage:prepare && npm run coverage:report && npm run coverage:check",
    "test": "npm run test:lint && npm run test:unit"
  },
  "lint-staged": {
    "*.{lua,luau}": "stylua"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KevMP/KRF.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KevMP/KRF/issues"
  },
  "homepage": "https://github.com/KevMP/KRF#readme",
  "nyc": {
    "temp-dir": ".nyc_output",
    "report-dir": "coverage",
    "extension": [
      ".luau",
      ".lua"
    ],
    "reporter": [
      "html",
      "lcovonly",
      "json-summary",
      "cobertura",
      "text-summary",
      "text"
    ],
    "branches": 90,
    "functions": 90,
    "lines": 90,
    "statements": 90
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nyc": "^17.1.0"
  }
}
